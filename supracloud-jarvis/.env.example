# =============================================================================
# SupraCloud IRA — Environment Variables
# Copy this file to .env and fill in every value before starting.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=November@1997
POSTGRES_DB=jarvis_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=November@1997

# ── vLLM ─────────────────────────────────────────────────────────────────────
# A single API key protects both vLLM endpoints.
VLLM_API_KEY=ira-vllm-key-November@1997

# Model identifiers (HuggingFace Hub). Override to use locally cached models.
FAST_MODEL=hugging-quants/Meta-Llama-3.1-8B-Instruct-AWQ-INT4
DEEP_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# HuggingFace token — required for gated models (e.g. Llama 3.1).
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=ira-livekit-key-November@1997
LIVEKIT_API_SECRET=November@1997-LiveKit-Secret-Key-SupraCloud-IRA-2026-Secure

# ── IRA API ───────────────────────────────────────────────────────────────────
# Master secret for signing JWTs and encrypting sensitive data.
IRA_SECRET_KEY=November@1997-IRA-Secret-Key-2026-SupraCloud-Secure-Long-Key

# Admin credentials for the IRA web interface
IRA_ADMIN_USERNAME=admin
IRA_ADMIN_PASSWORD=November@1997

# Your domain or server IP (used by nginx for TLS and CORS)
IRA_DOMAIN=localhost

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DEVICE=cpu

# ── Voice Layer ───────────────────────────────────────────────────────────────
# API token for ira-voice to authenticate with ira-api
IRA_VOICE_API_TOKEN=November@1997-IRA-Voice-Token-SupraCloud-2026-Secure

# Whisper model: large-v3 (best), medium (faster), small (fastest)
WHISPER_MODEL=large-v3

# IRA's primary voice — af_bella (warm) or af_heart (softer)
IRA_VOICE=af_bella

# ── Proactive Intelligence ────────────────────────────────────────────────────
# Morning briefing hour in UTC (default: 8 = 08:00 UTC)
BRIEFING_HOUR_UTC=8

# ── Telegram Notifications ────────────────────────────────────────────────────
# Create a bot at: https://t.me/BotFather
# Get your chat_id: message the bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email Notifications (SMTP) ────────────────────────────────────────────────
# Used for briefings and critical security alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=

# ── Calendar: Cal.com ─────────────────────────────────────────────────────────
# Get your API key from: https://app.cal.com/settings/developer/api-keys
CALCOM_API_KEY=
CALCOM_API_URL=https://api.cal.com

# ── Calendar: Google ──────────────────────────────────────────────────────────
# Path to your Google service account JSON file
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
