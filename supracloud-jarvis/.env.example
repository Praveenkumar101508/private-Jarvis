# =============================================================================
# SupraCloud IRA — Environment Variables
# Copy this file to .env and fill in every value before starting.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=jarvis_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ── vLLM — 2026 Maximum Power Model Stack ────────────────────────────────────
# A single API key protects all vLLM endpoints.
# Generate with: openssl rand -hex 32
VLLM_API_KEY=CHANGE_ME_vllm_api_key_here

# ── Fast Path (conversational) ────────────────────────────────────────────────
# Shadow PC (RTX A4500 20GB):  Qwen/Qwen3-8B-AWQ       (~7GB VRAM)
# Cloud 2×H100:                Qwen/Qwen3-30B-A3B       (MoE, only 3B active)
FAST_MODEL=Qwen/Qwen3-8B-AWQ

# ── Deep Path (code, reasoning, complex tasks) ────────────────────────────────
# Shadow PC (RTX A4500 20GB):  Qwen/Qwen3-14B-AWQ      (~12GB VRAM)
# Cloud 4×H100:                Qwen/Qwen3-72B           (dense, beats GPT-4o)
# Alternative (stronger R1):   deepseek-ai/DeepSeek-R1-Distill-Qwen-32B
DEEP_MODEL=Qwen/Qwen3-14B-AWQ

# ── Reasoning Path (Think Mode, DeepSearch) ───────────────────────────────────
# OPTIONAL — falls back to Deep Path if not set.
# Cloud 8×H100:  deepseek-ai/DeepSeek-R1 (671B, world's best open-source reasoning)
# Cloud 4×H100:  Qwen/Qwen3-235B-A22B    (MoE, 22B active — near-R1 quality)
VLLM_REASONING_URL=
VLLM_REASONING_MODEL=qwen3-reasoning

# ── Vision Path (image analysis) ──────────────────────────────────────────────
# OPTIONAL — falls back to fast text model if not set.
# Cloud 4×H100:  Qwen/Qwen3-VL-72B-Instruct-AWQ (beats Gemini 1.5 Pro on vision)
VLLM_VISION_URL=
VLLM_VISION_MODEL=qwen3-vl

# HuggingFace token — required for gated models.
# Get at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_CHANGE_ME

# ── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=CHANGE_ME_livekit_api_key
LIVEKIT_API_SECRET=CHANGE_ME_livekit_api_secret

# ── IRA API ───────────────────────────────────────────────────────────────────
# Master secret for signing JWTs.
# Generate with: openssl rand -hex 32
IRA_SECRET_KEY=CHANGE_ME_ira_secret_key_here

# Admin credentials for the IRA web interface
IRA_ADMIN_USERNAME=admin
IRA_ADMIN_PASSWORD=CHANGE_ME_strong_password_here

# Your domain (used by nginx for TLS and CORS)
IRA_DOMAIN=jarvis.local

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# Use 'cpu' inside Docker (GPU VRAM is reserved for vLLM); 'cuda' if running outside Docker
EMBEDDING_DEVICE=cpu

# ── Proactive Agent ───────────────────────────────────────────────────────────
# Morning briefing hour in UTC (default: 8 = 08:00 UTC)
BRIEFING_HOUR_UTC=8

# ── Voice Layer ───────────────────────────────────────────────────────────────
# API token for ira-voice to authenticate with ira-api
# Generate with: openssl rand -hex 32
IRA_VOICE_API_TOKEN=CHANGE_ME_voice_token_here

# Whisper model: large-v3 (best), medium (faster), small (fastest / Shadow PC)
WHISPER_MODEL=large-v3

# IRA's primary voice — af_bella (warm) or af_heart (softer)
IRA_VOICE=af_bella

# ── Telegram Notifications ────────────────────────────────────────────────────
# Create a bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email Notifications (SMTP) ────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=

# ── Calendar: Cal.com ─────────────────────────────────────────────────────────
CALCOM_API_KEY=
CALCOM_API_URL=https://api.cal.com

# ── Webhooks ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=CHANGE_ME_webhook_secret_here

# ── Biometric Gate ────────────────────────────────────────────────────────────
OWNER_NAME=Swetha Devisetty
BIOMETRIC_THRESHOLD=0.75

# ── Career Tools (Phase 4) ────────────────────────────────────────────────────
# GitHub personal access token — create at https://github.com/settings/tokens
# Needs: repo (read), user (read)
GITHUB_TOKEN=

# Apify API token — free tier at https://apify.com
# Used for LinkedIn/Indeed job board scraping
APIFY_API_TOKEN=

# ── X / Twitter Real-Time Search ─────────────────────────────────────────────
# Get your Bearer Token at https://developer.x.com → Projects → Your App → Keys
# The Basic plan (~$100/month) gives full recent search with country operators.
# The free tier is read-only and very limited — upgrade for production use.
TWITTER_BEARER_TOKEN=

# Optional cheap fallback: twitterapi.io (~$5–$50/month, no rate-limit headaches)
# Sign up at https://twitterapi.io — drop in your key below for automatic fallback.
X_FALLBACK_API_URL=https://api.twitterapi.io
X_FALLBACK_API_KEY=

# ── Image Generation ──────────────────────────────────────────────────────────
# Option A: Local Stable Diffusion WebUI (Automatic1111)
#   Run: docker run -p 7860:7860 automatic1111/stable-diffusion-webui
IMAGE_GEN_URL=

# Option B: Replicate API (Flux Schnell — fast, cloud-hosted)
#   Sign up at https://replicate.com — free tier available for testing
REPLICATE_API_TOKEN=

# ── Image Generation ──────────────────────────────────────────────────────────
# Provider: replicate (default) | sd_webui | comfyui
IMAGE_GEN_PROVIDER=replicate

# ── Dev Mode (Shadow PC / local development) ──────────────────────────────────
# Set DEV_MODE=true to bypass biometrics, skip vLLM, and use Ollama locally.
# NEVER set to true in production.
DEV_MODE=false

# Ollama base URL — only used when DEV_MODE=true
# host.docker.internal resolves to Windows host from Docker/WSL2 containers
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Ollama model to use in dev mode
# 2026 recommended: ollama pull qwen3:8b  (best small model available)
DEV_MODEL=qwen3:8b
