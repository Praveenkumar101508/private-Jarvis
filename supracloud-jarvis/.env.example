# =============================================================================
# SupraCloud IRA — Environment (Ollama + Hermes era)
# Copy to .env and fill in every value before starting. NEVER commit .env.
#
# IRA runs NATIVE on Windows (Shadow PC): local Ollama for inference, with the
# Hermes agent gateway out-of-process. Nothing leaves the box. The legacy vLLM
# section near the bottom is DORMANT (kept only because the upgrade path uses it).
# =============================================================================

# ── REQUIRED SECRETS ──────────────────────────────────────────────────────────
# Generate the *_KEY / *_SECRET values with:  openssl rand -hex 32
IRA_SECRET_KEY=CHANGE_ME_ira_secret_key_here          # signs JWTs
IRA_ADMIN_USERNAME=admin                              # the verified OWNER's login
IRA_ADMIN_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
REDIS_PASSWORD=CHANGE_ME_redis_password_here
# Still REQUIRED by the settings schema even on Ollama — any non-empty value is fine.
VLLM_API_KEY=unused-on-ollama-but-required

# ── ENGINE: local inference backend ───────────────────────────────────────────
# "ollama" (default) = local native Ollama. "vllm" = the dormant GPU/Docker path.
# This is INDEPENDENT of DEV_MODE — with ollama, auth + biometric gates stay ON.
LLM_BACKEND=ollama
# OpenAI-compatible Ollama endpoint (keep LOCAL).
OLLAMA_BASE_URL=http://localhost:11434/v1
# Tiered models. Two-model stack on the 20GB A4500 — pull BOTH:
#   ollama pull qwen3:8b    (fast / voice — low latency)
#   ollama pull qwen3:14b   (deep / reasoning)
OLLAMA_MODEL_FAST=qwen3:8b
OLLAMA_MODEL_DEEP=qwen3:14b
OLLAMA_MODEL_REASONING=qwen3:14b
# Keep models resident between turns for faster TTFT. start-ira.ps1 also sets
# OLLAMA_FLASH_ATTENTION=1 / OLLAMA_KV_CACHE_TYPE=q8_0 so both fit warm together.
OLLAMA_KEEP_ALIVE=30m
# Local vision-language model (Phase 3). Pull on Shadow:  ollama pull qwen2.5vl
OLLAMA_VISION_MODEL=qwen2.5vl

# ── HERMES engine (the agent engine, reached via the `hermes -z` subprocess) ──
# When true, IRA routes chat AND voice through Hermes via the bridge. Hermes adds a
# hop, so for the LOWEST voice latency keep this false (direct Ollama, qwen3:8b);
# both engines work and return real replies. (IRA_HERMES_URL/KEY below are back-
# compat only — 0.15.2 has no HTTP gateway; the bridge shells out to `hermes -z`.)
IRA_USE_HERMES=true
# MUST stay local (127.0.0.1/localhost) — a non-local URL is warned about loudly at
# startup because prompts would leave the box through a remote gateway.
IRA_HERMES_URL=http://127.0.0.1:8642/v1
# MUST equal Hermes' API_SERVER_KEY.
IRA_HERMES_KEY=CHANGE_ME_must_equal_hermes_API_SERVER_KEY
IRA_HERMES_MODEL=hermes-agent
IRA_HERMES_TIMEOUT=300

# ── SOVEREIGN WEB RESEARCH (Phase 3B) — self-hosted backends only ─────────────
# Keep both LOCAL/self-hosted; non-local values are warned about at startup so
# research queries can't leave the box. Optional — research fails soft if down.
SEARXNG_URL=http://localhost:8888            # self-hosted SearXNG (search)
CRAWL4AI_URL=http://localhost:11235          # self-hosted Crawl4AI (clean web reader)
WEB_SEARCH_ENABLED=true

# ── OWNER / BIOMETRIC GATE ────────────────────────────────────────────────────
OWNER_NAME=CHANGE_ME_your_name               # your real name
BIOMETRIC_THRESHOLD=0.75                     # cosine-similarity floor for voice auth (fail-closed below)

# ── Database / cache hosts (native = localhost) ───────────────────────────────
POSTGRES_USER=jarvis
POSTGRES_DB=jarvis_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Embeddings (memory) ───────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DEVICE=cpu                         # keep VRAM free for the 14B

# ── Voice (browser-native — the DEFAULT working path; no LiveKit needed) ──────
# Backend TTS/STT engines (read by ira-api):
IRA_VOICE_ENGINE=supertonic                   # supertonic (on-device, female) | kokoro (legacy)
IRA_VOICE=F1                                  # Supertonic F1–F5 (female) / M1–M5 (male); Kokoro: af_bella
IRA_TTS_STEPS=6                               # synthesis steps — low = faster first audio
WHISPER_MODEL=distil-large-v3                 # English (fast). For spoken Tamil/Hindi etc. use large-v3
WHISPER_VAD_MIN_SILENCE_MS=700                # higher = don't clip on a brief pause (accented/partial speech)
WHISPER_VAD_MIN_SPEECH_MS=200
# Native Indic TTS for Tamil/Telugu/Kannada/Malayalam (Hindi stays on Supertonic).
# Fail-soft: if the model isn't installed, those languages use Supertonic's 'na'.
IRA_INDIC_TTS_ENGINE=indic-parler             # indic-parler | none
IRA_INDIC_TTS_MODEL=ai4bharat/indic-parler-tts  # HF id or local path
# IRA_INDIC_TTS_VOICE=A female speaker delivers clear, natural speech.
#
# Frontend browser voice loop — Next.js only exposes NEXT_PUBLIC_* to the browser:
NEXT_PUBLIC_VOICE_TRANSPORT=browser           # browser (default) | livekit (legacy)
NEXT_PUBLIC_VOICE_ACTIVATION=wakeword         # wakeword | clap
NEXT_PUBLIC_WAKE_WORD=hey ira                 # trigger phrase for wakeword mode
NEXT_PUBLIC_VOICE_STT=whisper                 # whisper (sovereign, local) | webspeech (fast, NOT private — shows a badge)
NEXT_PUBLIC_PWA=true                          # install/offline service worker (production only); set false to disable
#
# ── Voice (LiveKit — LEGACY; only when NEXT_PUBLIC_VOICE_TRANSPORT=livekit) ────
LIVEKIT_API_KEY=CHANGE_ME_livekit_api_key
LIVEKIT_API_SECRET=CHANGE_ME_livekit_api_secret
LIVEKIT_ROOM_NAME=ira-voice
LIVEKIT_PUBLIC_URL=ws://localhost:7880
# Signed JWT (sub=ira-voice) the LiveKit voice agent uses to call ira-api.
IRA_VOICE_API_TOKEN=

# ── Coding agent (Aider — sovereign by default, owner-gated, branch-only) ──────
# Voice/text coding requests ("fix the bug in x.py") run Aider on a fresh branch.
# Install on the box: pipx install aider-chat ; ollama pull qwen2.5-coder:14b
CODER_BACKEND=local                            # local (Ollama coder) | claude (cloud — logged)
CODER_MODEL=qwen2.5-coder:14b                  # fits 20GB. 32B (qwen2.5-coder:32b) only on 24GB+ GPU
CODER_CLAUDE_MODEL=sonnet                      # aider's Claude alias (used only when CODER_BACKEND=claude)
CODING_REQUIRE_OWNER=true                      # refuse coding for non-owner when biometrics are on
CODER_ALLOWED_REPOS=                           # comma-separated absolute repo paths (blank = any)
# CODER_REPO_PATH=                             # default repo to edit (blank = the IRA package dir)
# CODER_TEST_CMD=pytest -q                     # test command run after editing

# ── Strategy mode (bounded deliberation — ranked, honest option analysis) ─────
# Triggered only by explicit strategic asks ("should I…", "best strategy…"); multi-call.
STRATEGY_BRANCHES=4                            # candidate options to weigh
STRATEGY_DEPTH=1                               # lookahead steps (hard-capped at 2)
STRATEGY_SELF_CONSISTENCY=1                    # >1 = sample N times and average the estimates
STRATEGY_DEEP_SYNTHESIS=true                   # use the deep (qwen3:14b) tier for the analysis
STRATEGY_CALIBRATION_ENABLED=true              # Phase 6: calibrate success estimates against the owner's own recorded outcomes

# ── Identity / domain ─────────────────────────────────────────────────────────
IRA_DOMAIN=jarvis.local
# Phone access over Tailscale Serve (HTTPS — required for the mobile mic). Set to your
# box's MagicDNS host so CORS allows the phone's origin. See TAILSCALE_SETUP.md.
IRA_TS_HOST=                                  # e.g. shadow.tailnet-name.ts.net
# Browser API base — leave BLANK for same-origin (tailscale serve path-routes /api).
# Set only if the API is served from a different host than the frontend.
NEXT_PUBLIC_API_BASE=
IRA_GIT_AUTHOR_EMAIL=CHANGE_ME_your_email@example.com   # author for Architect-apply commits

# ── Proactive agent ───────────────────────────────────────────────────────────
BRIEFING_HOUR_UTC=8
BRIEFING_TIMEZONE=Asia/Kolkata

# ── Actions (all fail soft when unset — see /api/v1/actions) ──────────────────
# Calendar (Cal.com)
CALCOM_API_KEY=
CALCOM_API_URL=https://api.cal.com
# Email-with-approval (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=
# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── P5.2 Canary tokens / tripwires ────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
# Leave blank to disable the corresponding tripwire (all are optional).
# IRA_CANARY_TOKEN: a fake bearer token — any API request using this value fires CRITICAL.
IRA_CANARY_TOKEN=
# IRA_CANARY_USERNAME: a ghost login name — any login attempt for it fires CRITICAL.
IRA_CANARY_USERNAME=

# ── Webhooks / business ───────────────────────────────────────────────────────
WEBHOOK_SECRET=CHANGE_ME_webhook_secret_here
HOT_LEAD_KEYWORDS=urgent,asap,immediately,enterprise,critical
HOT_LEAD_BUDGETS=enterprise,250k+,100k-250k

# ── Optional integrations (career / media / X) — all blank = disabled ─────────
GITHUB_TOKEN=
APIFY_API_TOKEN=
TWITTER_BEARER_TOKEN=
X_FALLBACK_API_URL=https://api.twitterapi.io
X_FALLBACK_API_KEY=
IMAGE_GEN_PROVIDER=replicate
REPLICATE_API_TOKEN=

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_DIR=/backups
BACKUP_KEEP=7

# ── Observability (OpenTelemetry) — blank = disabled ──────────────────────────
OTLP_ENDPOINT=
OTLP_HEADERS=

# ── Auth token lifetimes (P2.1) ──────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30       # access token lifetime; shorter = smaller stolen-token window
REFRESH_TOKEN_EXPIRE_DAYS=7          # refresh token lifetime; used to obtain new access tokens

# ── DEV MODE — local only, NEVER in production ────────────────────────────────
# DEV_MODE=true bypasses auth + biometrics and auto-authenticates as admin.
# It is NOT required for local Ollama — LLM_BACKEND=ollama already runs locally
# with the gates ON. Leave false unless you are deliberately disabling security.
DEV_MODE=false

# =============================================================================
# LEGACY / DORMANT — vLLM GPU path (only for the 8xH100 scale-up). Not used on the
# Shadow PC. Kept because the cloud upgrade flips LLM_BACKEND=vllm and sets these.
# =============================================================================
# VLLM_FAST_URL / VLLM_DEEP_URL / VLLM_REASONING_URL / VLLM_VISION_URL ...
VLLM_FAST_MODEL=qwen3-fast
VLLM_DEEP_MODEL=qwen3-deep
VLLM_REASONING_URL=
VLLM_REASONING_MODEL=qwen3-reasoning
VLLM_VISION_URL=
VLLM_VISION_MODEL=qwen3-vl
HF_TOKEN=
