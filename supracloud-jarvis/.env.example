# =============================================================================
# SupraCloud Jarvis — Environment Variables
# Copy this file to .env and fill in every value before starting.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=jarvis_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ── vLLM ─────────────────────────────────────────────────────────────────────
# A single API key protects both vLLM endpoints.
# Generate with: openssl rand -hex 32
VLLM_API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Model identifiers (HuggingFace Hub). Override to use locally cached models.
FAST_MODEL=hugging-quants/Meta-Llama-3.1-8B-Instruct-AWQ-INT4
DEEP_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# HuggingFace token — required for gated models (e.g. Llama 3.1).
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_CHANGE_ME

# ── LiveKit ───────────────────────────────────────────────────────────────────
# Generate both with: openssl rand -hex 16
LIVEKIT_API_KEY=CHANGE_ME_livekit_api_key
LIVEKIT_API_SECRET=CHANGE_ME_livekit_api_secret

# ── Jarvis API (Phase 2) ──────────────────────────────────────────────────────
# Master secret for signing JWTs and encrypting sensitive data.
# Generate with: openssl rand -hex 32
JARVIS_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# Admin credentials for the Jarvis web interface
JARVIS_ADMIN_USERNAME=admin
JARVIS_ADMIN_PASSWORD=CHANGE_ME_strong_password_here

# Your domain (used by nginx for TLS and CORS)
JARVIS_DOMAIN=jarvis.local

# ── Embeddings (Phase 2) ──────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DEVICE=cuda

# ── Proactive Agent (Phase 4) ─────────────────────────────────────────────────
# Cron-style schedule for daily briefings (UTC)
BRIEFING_SCHEDULE=0 8 * * *

# ── Optional: External Integrations (Phase 5+) ───────────────────────────────
# Only fill in what you need — Jarvis works fully without these.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SLACK_WEBHOOK_URL=
# GITHUB_TOKEN=
