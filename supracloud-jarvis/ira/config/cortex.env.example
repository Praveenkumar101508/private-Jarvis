# Cortex engine — subprocess (`cortex -z`) wiring (verified on the Shadow PC, 2026-06-11)
# Copy these names into your real env; DO NOT put secrets in this file.
#
# IMPORTANT (verified against the installed hermes-agent 0.15.2): there is NO local,
# key-gated, OpenAI-compatible gateway on :8642 and no API_SERVER_KEY. `cortex gateway`
# is the *messaging* gateway; `cortex proxy` only forwards to *cloud* providers. So the
# IRA bridge (ira/cortex_bridge.py) shells out to the `cortex -z` one-shot CLI instead,
# which runs the full agent against LOCAL Ollama configured in Cortex' own config.yaml.

# --- Cutover engine switch ---
# false (DEFAULT) → IRA serves chat/voice via the legacy LangGraph agents (unchanged).
# true            → chat (and voice, via /chat/stream) routes through the Cortex bridge:
#                   router.enforce_owner_gate() → ira/skills/* (subagents for Expert Mode).
IRA_USE_CORTEX=true

# --- Subprocess bridge knobs (ira/cortex_bridge.py) ---
IRA_CORTEX_TIMEOUT=300                       # per-call timeout (seconds)
# IRA_CORTEX_BIN=                            # full path to hermes.exe; else resolved on PATH,
#                                            #   else %LOCALAPPDATA%\hermes\hermes-agent\venv\Scripts\hermes.exe
# IRA_CORTEX_CWD=                            # working dir for the agent subprocess (default: ira/)

# Retained for back-compat with the old HTTP design — UNUSED on the subprocess path
# (no gateway, no key gate). IRA_CORTEX_URL still satisfies the startup local-only guard.
IRA_CORTEX_URL=http://127.0.0.1:8642/v1
IRA_CORTEX_KEY=
IRA_CORTEX_MODEL=hermes-agent                # advisory; the real model lives in Cortex config.yaml

# --- How Cortex itself is configured (runs OUT-OF-PROCESS, native Windows, NOT in IRA's venv) ---
# Config path:    %LOCALAPPDATA%\cortex\config.yaml   (NOT ~/.cortex/...). Keys nest under `model:`.
# Point it at LOCAL Ollama (sovereign) — with no config it defaults to OpenRouter CLOUD:
#   cortex config set model.provider custom
#   cortex config set model.base_url http://localhost:11434/v1
#   cortex config set model.default qwen3:14b
#   cortex config set model.context_length 65536
#   cortex config set model.ollama_num_ctx 65536      # Cortex needs >=64K; makes Ollama load 14b at 64K
# Models pulled:  ollama pull qwen3:14b   (+ qwen2.5vl for vision)
# Verify local:   cortex -z "/no_think Reply with exactly: PONG"   → PONG from local qwen3:14b
