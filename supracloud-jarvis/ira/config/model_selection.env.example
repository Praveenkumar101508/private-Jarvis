# IRA smart model selection — environment example
# =================================================
# Copy the values you want into your .env. All are optional: with none set, IRA
# runs the local-first `balanced_local` profile and never uses an external API.
#
# See docs/MODEL_SELECTION.md for the full explanation.

# Active profile: balanced_local (default) | low_resource | strong_local
IRA_MODEL_PROFILE=balanced_local

# Per-mode overrides (win over the profile). Set only the ones you want to change.
IRA_LOCAL_FAST_MODEL=qwen3:8b
IRA_LOCAL_MAIN_MODEL=qwen3:14b
IRA_LOCAL_REASONING_MODEL=deepseek-r1:14b
IRA_LOCAL_CODING_MODEL=qwen3-coder-next
IRA_LOCAL_VISION_MODEL=gemma3:12b
IRA_EMBEDDING_MODEL=bge-m3
IRA_FALLBACK_TINY_MODEL=gemma3n:e4b

# External API consent gate. Defaults keep IRA fully local.
IRA_ALLOW_EXTERNAL_API=false     # master switch; must be true before any external call
IRA_REQUIRE_API_CONSENT=true     # always ask before using an external API
IRA_PRIVACY_MODE=local_first     # local_only | local_first | external_ok

# Only used if you approve Deep Intelligence Mode AND set IRA_ALLOW_EXTERNAL_API=true.
# The actual provider integration is wired by the caller; these just name the target.
# IRA_EXTERNAL_API_PROVIDER=anthropic
# IRA_EXTERNAL_API_MODEL=claude-opus-4-8

# Where to probe installed local models (native Ollama tags endpoint root).
# IRA_OLLAMA_BASE_URL=http://localhost:11434
