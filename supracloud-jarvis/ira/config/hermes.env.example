# Phase 1 — Hermes out-of-process gateway (verified on the Shadow PC, 2026-06-03)
# Copy these names into your real env; DO NOT put secrets in this file.
# The IRA bridge (Phase 2) reads these:

IRA_HERMES_URL=http://127.0.0.1:8642/v1     # Hermes gateway (OpenAI-compatible API server)
IRA_HERMES_MODEL=hermes-agent               # model id the gateway exposes (from GET /v1/models)
IRA_HERMES_KEY=                             # == Hermes API_SERVER_KEY. Lives in ~/.hermes/.env. NEVER commit.

# --- How Hermes itself is configured (runs OUT-OF-PROCESS, native Windows, NOT in IRA's venv) ---
# Install:        iex (irm https://raw.githubusercontent.com/NousResearch/hermes-agent/main/scripts/install.ps1)
#                 (installs under %LOCALAPPDATA%\hermes; config at ~/.hermes/config.yaml + ~/.hermes/.env)
# Model backend:  Ollama @ http://localhost:11434/v1   (model.provider=custom)
# Models pulled:  qwen3:8b (fast, ~5.2GB)  /  qwen3:14b (deep, ~9.3GB)
# Gateway:        hermes gateway   (env: API_SERVER_ENABLED=true, API_SERVER_HOST=127.0.0.1, API_SERVER_KEY=<hex>)
#
# IMPORTANT — Hermes requires >=64K context for tool use. Set BOTH in ~/.hermes/config.yaml:
#   model.context_length: 65536
#   model.ollama_num_ctx: 65536
# qwen3:8b @ 64K fits the A4500 (~15GB). NOTE: qwen3:14b @ 64K ~= 21GB -> OOM on 20GB;
# to use the deep model, quantize the KV cache (e.g. OLLAMA_KV_CACHE_TYPE=q8_0) or keep deep off this box.
