# Hermes engine — subprocess (`hermes -z`) wiring (verified on the Shadow PC, 2026-06-11)
# Copy these names into your real env; DO NOT put secrets in this file.
#
# IMPORTANT (verified against the installed hermes-agent 0.15.2): there is NO local,
# key-gated, OpenAI-compatible gateway on :8642 and no API_SERVER_KEY. `hermes gateway`
# is the *messaging* gateway; `hermes proxy` only forwards to *cloud* providers. So the
# IRA bridge (ira/hermes_bridge.py) shells out to the `hermes -z` one-shot CLI instead,
# which runs the full agent against LOCAL Ollama configured in Hermes' own config.yaml.

# --- Cutover engine switch ---
# false (DEFAULT) → IRA serves chat/voice via the legacy LangGraph agents (unchanged).
# true            → chat (and voice, via /chat/stream) routes through the Hermes bridge:
#                   router.enforce_owner_gate() → ira/skills/* (subagents for Expert Mode).
IRA_USE_HERMES=true

# --- Subprocess bridge knobs (ira/hermes_bridge.py) ---
IRA_HERMES_TIMEOUT=300                       # per-call timeout (seconds)
# IRA_HERMES_BIN=                            # full path to hermes.exe; else resolved on PATH,
#                                            #   else %LOCALAPPDATA%\hermes\hermes-agent\venv\Scripts\hermes.exe
# IRA_HERMES_CWD=                            # working dir for the agent subprocess (default: ira/)

# Retained for back-compat with the old HTTP design — UNUSED on the subprocess path
# (no gateway, no key gate). IRA_HERMES_URL still satisfies the startup local-only guard.
IRA_HERMES_URL=http://127.0.0.1:8642/v1
IRA_HERMES_KEY=
IRA_HERMES_MODEL=hermes-agent                # advisory; the real model lives in Hermes config.yaml

# --- How Hermes itself is configured (runs OUT-OF-PROCESS, native Windows, NOT in IRA's venv) ---
# Config path:    %LOCALAPPDATA%\hermes\config.yaml   (NOT ~/.hermes/...). Keys nest under `model:`.
# Point it at LOCAL Ollama (sovereign) — with no config it defaults to OpenRouter CLOUD:
#   hermes config set model.provider custom
#   hermes config set model.base_url http://localhost:11434/v1
#   hermes config set model.default qwen3:14b
#   hermes config set model.context_length 65536
#   hermes config set model.ollama_num_ctx 65536      # Hermes needs >=64K; makes Ollama load 14b at 64K
# Models pulled:  ollama pull qwen3:14b   (+ qwen2.5vl for vision)
# Verify local:   hermes -z "/no_think Reply with exactly: PONG"   → PONG from local qwen3:14b
