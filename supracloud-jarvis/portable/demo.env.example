# ─────────────────────────────────────────────────────────────────────────────
# IRA — Portable Demo environment (V2)
# Copy to .env next to the portable launcher. These defaults are SAFE out of the
# box: IRA_MODE=portable_demo is a guard rail that refuses to start if any of the
# hardened settings below are flipped to an unsafe value.
# ─────────────────────────────────────────────────────────────────────────────

# Lock the deployment into the hardened portable composition.
IRA_MODE=portable_demo

# ── Reasoning engine: fully local, no keys ───────────────────────────────────
LLM_BACKEND=ollama          # local Ollama; no VLLM_API_KEY needed. Use "mock" for a
                            # zero-dependency UI demo (set IRA_LLM_BACKEND=mock).
IRA_USE_CORTEX=false        # native LangGraph reasoning; no Cortex binary required
# IRA_LLM_BACKEND=ollama    # reasoning-backend selector: ollama (default) or mock

# ── Egress: OFF (local-first) ────────────────────────────────────────────────
WEB_SEARCH_ENABLED=false    # no external web search
IMAGE_GEN_PROVIDER=sd_webui # local image gen; "replicate" (cloud) stays opt-in
# Cloud tokens intentionally blank — leave them empty for the demo:
REPLICATE_API_TOKEN=
APIFY_API_TOKEN=
TAVILY_API_KEY=
SERPER_API_KEY=

# ── Unsafe actuators: OFF ────────────────────────────────────────────────────
ANDROID_ACTUATOR_ENABLED=false

# ── Security posture: production-like, bound to localhost ────────────────────
DEV_MODE=false              # auth + biometric gates stay ON
API_BIND_HOST=127.0.0.1     # never expose the demo on the LAN
ALLOW_DEV_MODE_EXPOSED=false

# ── Infra secrets (set real values; the portable launcher can generate these) ─
IRA_SECRET_KEY=change-me-to-a-long-random-string
IRA_ADMIN_PASSWORD=change-me
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me
