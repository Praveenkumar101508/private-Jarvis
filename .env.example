# ============================================================
# IRA (Intelligent Responsive Assistant) — Environment Config
# Copy this file to .env and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=IRA
APP_ENV=production
APP_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── LLM Provider ─────────────────────────────────────────────
# Options: openai | anthropic | groq | ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Model names
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local fallback) ───────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ── Sovereign Mode — Dual-Node Ollama Routing ─────────────────
# Thin-client (MacBook Air M1): fast intent-routing model
OLLAMA_FAST_MODEL=llama3.1:8b
# Shadow PC (NVIDIA RTX A4500) reached via Tailscale mesh: heavy reasoning
OLLAMA_HEAVY_MODEL=qwen2.5-coder:32b
OLLAMA_HEAVY_URL=http://100.x.x.x:11434  # Replace with Shadow PC Tailscale IP

# ── Voice — LiveKit ──────────────────────────────────────────
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ── Voice — STT ──────────────────────────────────────────────
# Options: faster_whisper (sovereign/local) | deepgram | google
STT_PROVIDER=faster_whisper
DEEPGRAM_API_KEY=...
WHISPER_MODEL=base
# Sovereign STT tuning — faster-whisper device and precision
WHISPER_DEVICE=auto         # auto | cpu | cuda | mps
WHISPER_COMPUTE_TYPE=int8   # int8 | float16 | float32

# ── Voice — TTS ──────────────────────────────────────────────
# Options: kokoro (sovereign/local) | elevenlabs | azure | google
TTS_PROVIDER=kokoro
ELEVENLABS_API_KEY=...
# IRA voice ID — warm Indian female voice
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
AZURE_TTS_KEY=...
AZURE_TTS_REGION=eastus
AZURE_TTS_VOICE=en-IN-NeerjaNeural
# Sovereign TTS — kokoro ONNX local model paths (relative to repo root)
KOKORO_MODEL_PATH=backend/voice/models/kokoro-v0_19.onnx
KOKORO_VOICES_PATH=backend/voice/models/voices.bin
KOKORO_VOICE=af_sarah
KOKORO_SPEED=1.0

# ── Memory — Redis ───────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ── Memory — Vector DB ───────────────────────────────────────
# Options: chroma | qdrant | pinecone
VECTOR_DB=chroma
CHROMA_HOST=chromadb
CHROMA_PORT=8001
QDRANT_URL=http://qdrant:6333
PINECONE_API_KEY=...
PINECONE_ENV=us-east1-gcp

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ira:ira_pass@postgres:5432/ira_db
POSTGRES_DB=ira_db
POSTGRES_USER=ira
POSTGRES_PASSWORD=ira_pass

# ── Web Search ───────────────────────────────────────────────
SERP_API_KEY=...
TAVILY_API_KEY=...

# ── Calendar / Productivity ───────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Notifications ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
WHATSAPP_API_KEY=...

# ── Multilingual ─────────────────────────────────────────────
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,hi,te,ta,kn,mr,bn,gu,pa,ml

# ── Proactive Worker ─────────────────────────────────────────
PROACTIVE_WORKER_INTERVAL=300
MORNING_BRIEFING_TIME=07:30
TIMEZONE=Asia/Kolkata

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
